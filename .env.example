# Copy this file to `.env` (which is gitignored) for LOCAL runs only.
# NEVER commit real values. In GitHub Actions these come from repo secrets.

# Amadeus Self-Service (free production key from https://developers.amadeus.com)
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
AMADEUS_ENV=production

# Email (only needed if you send reports locally; Actions uses secrets)
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=your-gmail-app-password
# MAIL_TO=you@gmail.com
